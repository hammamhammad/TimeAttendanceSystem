# ==========================================================================
# TecAxle HRMS .gitignore
# ==========================================================================

# --- .NET / C# build output ------------------------------------------------
**/bin/
**/obj/
*.dll
*.exe
*.pdb
*.cache
*.nuget.g.*
project.lock.json
project.assets.json
*.csproj.user
*.csproj.FileListAbsolute.txt

# Visual Studio / Rider / VS Code meta
.vs/
.vscode/
.idea/
*.suo
*.user
*.sln.docstates

# --- Node / Angular / frontend build output --------------------------------
node_modules/
time-attendance-frontend/dist/
time-attendance-selfservice-frontend/dist/
**/.angular/cache/
**/.angular/compiler-cache/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.tsbuildinfo

# --- Claude Code per-user settings -----------------------------------------
# (The committed .claude/settings.json is the shared config; settings.local.json
#  and settings.{user}.json are per-developer and should not be tracked.)
.claude/settings.local.json
.claude/settings.*.local.json

# --- OS / editor noise -----------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
*~

# --- Secrets / runtime -----------------------------------------------------
.env
.env.local
.env.*.local
compose/.env
appsettings.Local.json
*.log

# --- Project-specific (preserved from prior .gitignore) -------------------
nul
*.apk
publish/
reverse-proxy/
__pycache__/
scripts/r.sh
scripts/remote-exec.py

# --- Uploads (local dev) ---------------------------------------------------
uploads/
