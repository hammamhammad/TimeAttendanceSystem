		<string>ClockN ESS needs NFC access to scan attendance tags at your branch.</string>
		<key>NSFaceIDUsageDescription</key>
		<string>ClockN ESS uses Face ID for secure biometric login.</string>
		<key>NSCameraUsageDescription</key>
		<string>ClockN ESS may need camera access for document uploads.</string>
